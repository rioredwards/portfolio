{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "basics": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email",
          "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
        },
        "phone": {
          "type": "string"
        },
        "website": {
          "type": "string",
          "format": "uri"
        },
        "linkedIn": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": ["name", "title", "email", "phone", "linkedIn"],
      "additionalProperties": false
    },
    "summary": {
      "type": "string"
    },
    "experience": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "startDate": {
                "type": "string",
                "pattern": "^\\d{4}(-\\d{2})?$"
              },
              "endDate": {
                "type": "string",
                "pattern": "^\\d{4}(-\\d{2})?$"
              },
              "projects": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "title": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "tech": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "url": {
                      "type": "string",
                      "format": "uri"
                    }
                  },
                  "required": ["title", "description", "tech"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["name", "title", "startDate", "projects"],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "startDate": {
                "type": "string",
                "pattern": "^\\d{4}(-\\d{2})?$"
              },
              "endDate": {
                "type": "string",
                "pattern": "^\\d{4}(-\\d{2})?$"
              },
              "highlights": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": ["name", "title", "startDate", "highlights"],
            "additionalProperties": false
          }
        ]
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "institution": {
            "type": "string"
          },
          "certificate": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}(-\\d{2})?$"
          }
        },
        "required": ["institution", "certificate", "date"],
        "additionalProperties": false
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string"
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["category", "skills"],
        "additionalProperties": false
      }
    },
    "sideProjects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tech": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": ["title", "description", "tech"],
        "additionalProperties": false
      }
    }
  },
  "required": ["basics", "summary", "experience", "education", "skills"],
  "additionalProperties": false
}
