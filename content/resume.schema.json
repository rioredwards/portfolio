{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Career Resume",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "basics",
    "summary",
    "experience",
    "education",
    "skills"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "base", "targetRole", "company", "updatedAt"],
      "properties": {
        "slug": {
          "type": "string",
          "minLength": 1
        },
        "base": {
          "type": "string",
          "minLength": 1
        },
        "targetRole": {
          "type": "string",
          "minLength": 1
        },
        "company": {
          "type": "string",
          "minLength": 1
        },
        "updatedAt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "basics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "title",
        "location",
        "email",
        "phone",
        "website",
        "linkedIn"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "minLength": 1
        },
        "phone": {
          "type": "string",
          "minLength": 1
        },
        "website": {
          "type": "string",
          "minLength": 1
        },
        "linkedIn": {
          "type": "string",
          "minLength": 1
        },
        "github": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "experience": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/experienceEntry"
      }
    },
    "sideProjects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sideProject"
      }
    },
    "education": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/educationEntry"
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/skillGroup"
      }
    }
  },
  "$defs": {
    "experienceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "company", "title", "startDate", "endDate"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "company": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "startDate": {
          "type": "string",
          "minLength": 1
        },
        "endDate": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "projects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/project"
          }
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "anyOf": [
        {
          "required": ["projects"]
        },
        {
          "required": ["highlights"]
        }
      ]
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "tech"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tech": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sideProject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "tech"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tech": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "educationEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "institution", "credential", "date"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "institution": {
          "type": "string",
          "minLength": 1
        },
        "credential": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "skillGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "items"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
